rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['urildlduri@gmail.com','liferefix@naver.com'];
    }
    function signedIn() { return request.auth != null; }

    match /nw_users/{uid} {
      allow read: if signedIn();
      allow create, update: if request.auth.uid == uid;
      allow delete: if isAdmin();
      match /history/{doc} {
        allow read, write: if request.auth.uid == uid;
      }
      match /points/{doc} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    match /nw_biz/{id} {
      allow read: if signedIn();
      allow create: if isAdmin()
        || (signedIn()
            && request.resource.data.ownerId == request.auth.uid
            && request.resource.data.approved == false);
      allow update: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid
            && request.resource.data.approved == resource.data.approved)
        || (signedIn() && resource.data.memberEmails is list
            && request.auth.token.email in resource.data.memberEmails
            && request.resource.data.ownerId == resource.data.ownerId
            && request.resource.data.approved == resource.data.approved
            && request.resource.data.memberEmails == resource.data.memberEmails)
        || (signedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['ratingAvg','ratingCount']));
      allow delete: if isAdmin();
    }

    match /nw_reviews/{rid} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /nw_calls/{id} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.callerId == request.auth.uid
        || request.resource.data.status in ['matched','accepted','going','done','noshow','cancelled','expired']
      );
      allow delete: if isAdmin()
        || (signedIn() && resource.data.callerId == request.auth.uid);
      match /responses/{bizId} {
        allow read: if signedIn();
        allow write: if signedIn();
      }
    }

    match /nw_community/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid)
        || (signedIn() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likes','commentCount']));
      allow delete: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
    }

    match /nw_hotplaces/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /nw_notices/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /nw_together/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }
  }
}
