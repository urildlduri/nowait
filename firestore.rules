rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['urildlduri@gmail.com'];
    }
    function signedIn() { return request.auth != null; }

    match /nw_users/{uid} {
      allow read: if signedIn();
      allow create, update: if request.auth.uid == uid;
      allow delete: if isAdmin();
      match /history/{doc} {
        allow read, write: if request.auth.uid == uid;
      }
    }

    match /nw_biz/{id} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.approved == false;
      allow update: if isAdmin()
        || (signedIn() && resource.data.ownerId == request.auth.uid
            && request.resource.data.approved == resource.data.approved);
      allow delete: if isAdmin();
    }

    match /nw_hotplaces/{id} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /nw_calls/{id} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.callerId == request.auth.uid
        || request.resource.data.status == 'matched'
      );
      allow delete: if isAdmin()
        || (signedIn() && resource.data.callerId == request.auth.uid);
      match /responses/{bizId} {
        allow read: if signedIn();
        allow write: if signedIn();
      }
    }
  }
}
